# ============================================
# SURVEY API TESTS
# ============================================

@baseUrl = http://localhost:8080/api/v1
@email = tester01@mail.com
@password = Password123!

### 0. LOGIN
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

###

@accessToken = {{login.response.body.data.access_token}}
@surveyId = {{createSurvey.response.body.data.id}}
@surveyToken = {{createSurvey.response.body.data.slug}}

### LOCALES - List semua bahasa
GET {{baseUrl}}/locales

###

# ============================================
# ADMIN SURVEY ENDPOINTS (Protected)
# ============================================

### 1. CREATE SURVEY - Buat survey baru
# @name createSurvey
POST {{baseUrl}}/admin/surveys
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Survey Gizi Mahasiswa 2024",
  "slug": "survey-gizi-2024",
  "description": "Survey asupan gizi harian mahasiswa",
  "meals_config": {
    "meals": [
      { "name": "Sarapan", "time": "07:00", "required": true, "prompt": "Makanan pagi hari" },
      { "name": "Makan Siang", "time": "12:00", "required": true, "prompt": "Makanan siang hari" },
      { "name": "Makan Malam", "time": "19:00", "required": true, "prompt": "Makanan malam hari" },
      { "name": "Snack", "time": "15:00", "required": false, "prompt": "Makanan ringan" }
    ]
  },
  "prompts": {
    "welcome": "Sebelum mengisi, pastikan ingat semua makanan yang dikonsumsi",
    "instructions": "Pilih waktu makan, lalu cari makanan yang kamu konsumsi."
  },
  "locale_id": 1,
  "start_date": "2024-01-01",
  "end_date": "2024-12-31"
}

### 2. LIST SURVEYS - Daftar semua survey
GET {{baseUrl}}/admin/surveys?page=1&limit=10
Authorization: Bearer {{accessToken}}

### 3. GET SURVEY DETAIL - Detail satu survey
GET {{baseUrl}}/admin/surveys/{{surveyId}}
Authorization: Bearer {{accessToken}}

### 4. UPDATE SURVEY - Update data survey
PUT {{baseUrl}}/admin/surveys/{{surveyId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Survey Gizi Mahasiswa 2024 (Updated)",
  "status": "active"
}

### 5. REGENERATE ACCESS TOKEN - Buat token baru
POST {{baseUrl}}/admin/surveys/{{surveyId}}/regenerate-token
Authorization: Bearer {{accessToken}}

### 6. CLONE SURVEY - Duplikat survey
POST {{baseUrl}}/admin/surveys/{{surveyId}}/clone
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "new_name": "Survey Gizi Mahasiswa 2025",
  "new_slug": "survey-gizi-2025"
}

### 7. DELETE SURVEY - Hapus survey
DELETE {{baseUrl}}/admin/surveys/{{surveyId}}
Authorization: Bearer {{accessToken}}

###

# ============================================
# RESPONDENT SURVEY ENDPOINTS (Guarded)
# ============================================

### 7.5. LIST ACTIVE SURVEYS - List semua survey aktif untuk respondent
GET {{baseUrl}}/survey/active
Authorization: Bearer {{accessToken}}

### 8. ACCESS SURVEY - Respondent masuk via token
# @name accessSurvey
POST {{baseUrl}}/survey/access
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "token": "survey-gizi-2024", 
  "alias": "Peserta 001",
  "respondent_name": "Budi Santoso"
}

### 9. GET SURVEY INFO - Ambil info survey
GET {{baseUrl}}/survey/{{surveyId}}/info
Authorization: Bearer {{accessToken}}

###

# ============================================
# ERROR TEST CASES
# ============================================

### 10. Create dengan slug duplikat (409 Conflict)
POST {{baseUrl}}/admin/surveys
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Survey Duplikat",
  "slug": "survey-gizi-2024",
  "meals_config": {
    "meals": [{ "name": "Test", "time": "12:00", "required": true }]
  }
}
