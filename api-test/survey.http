# ============================================
# SURVEY API TESTS
# ============================================

### LOCALES - List semua bahasa
GET http://localhost:8080/api/v1/locales

###

# ============================================
# ADMIN SURVEY ENDPOINTS (Protected)
# ============================================

### 1. CREATE SURVEY - Buat survey baru
POST http://localhost:8080/api/v1/admin/surveys
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Survey Gizi Mahasiswa 2024",
  "slug": "survey-gizi-2024",
  "description": "Survey asupan gizi harian mahasiswa",
  "meals_config": {
    "meals": [
      { "name": "Sarapan", "time": "07:00", "required": true, "prompt": "Makanan pagi hari" },
      { "name": "Makan Siang", "time": "12:00", "required": true, "prompt": "Makanan siang hari" },
      { "name": "Makan Malam", "time": "19:00", "required": true, "prompt": "Makanan malam hari" },
      { "name": "Snack", "time": "15:00", "required": false, "prompt": "Makanan ringan" }
    ]
  },
  "prompts": {
    "before_meals": "Sebelum mengisi, pastikan ingat semua makanan yang dikonsumsi",
    "after_meals": "Terima kasih telah mengisi survey",
    "missing_food": "Tambahkan makanan yang belum ada di database"
  },
  "locale_id": 1,
  "start_date": "2024-01-01",
  "end_date": "2024-12-31"
}

### 2. LIST SURVEYS - Daftar semua survey
GET http://localhost:8080/api/v1/admin/surveys?page=1&limit=10
Authorization: Bearer {{accessToken}}

### 3. GET SURVEY DETAIL - Detail satu survey
GET http://localhost:8080/api/v1/admin/surveys/{{surveyId}}
Authorization: Bearer {{accessToken}}

### 4. UPDATE SURVEY - Update data survey
PUT http://localhost:8080/api/v1/admin/surveys/{{surveyId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Survey Gizi Mahasiswa 2024 (Updated)",
  "status": "active"
}

### 5. REGENERATE ACCESS TOKEN - Buat token baru
POST http://localhost:8080/api/v1/admin/surveys/{{surveyId}}/regenerate-token
Authorization: Bearer {{accessToken}}

### 6. CLONE SURVEY - Duplikat survey
POST http://localhost:8080/api/v1/admin/surveys/{{surveyId}}/clone
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "new_name": "Survey Gizi Mahasiswa 2025",
  "new_slug": "survey-gizi-2025"
}

### 7. DELETE SURVEY - Hapus survey
DELETE http://localhost:8080/api/v1/admin/surveys/{{surveyId}}
Authorization: Bearer {{accessToken}}

###

# ============================================
# PUBLIC SURVEY ENDPOINTS (No Auth)
# ============================================

### 8. GET PUBLIC SURVEY - Akses survey via token
GET http://localhost:8080/api/v1/s/{{surveyAccessToken}}

### 9. JOIN SURVEY - Respondent bergabung
POST http://localhost:8080/api/v1/s/{{surveyAccessToken}}/join
Content-Type: application/json

{
  "alias": "Peserta 001"
}

###

# ============================================
# ERROR TEST CASES
# ============================================

### 10. Create dengan slug duplikat (409 Conflict)
POST http://localhost:8080/api/v1/admin/surveys
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Survey Duplikat",
  "slug": "survey-gizi-2024",
  "meals_config": {
    "meals": [{ "name": "Test", "time": "12:00", "required": true }]
  }
}

### 11. Get survey tidak ada (404 Not Found)
GET http://localhost:8080/api/v1/admin/surveys/invalid-id-123
Authorization: Bearer {{accessToken}}

### 12. Create survey tanpa auth (401 Unauthorized)
POST http://localhost:8080/api/v1/admin/surveys
Content-Type: application/json

{
  "name": "Test Survey",
  "slug": "test-survey",
  "meals_config": { "meals": [] }
}
