# ============================================
# KONFIGURASI DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=db_atlas_food

# ============================================
# KONFIGURASI JWT
# ============================================
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=168h

# ============================================
# KONFIGURASI SERVER
# ============================================
SERVER_PORT=8080
SERVER_MODE=debug

# ============================================
# KONFIGURASI UPLOAD FILE
# ============================================
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10485760
